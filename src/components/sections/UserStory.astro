---
// §9.5 "While the employees sleep" — anonymized (no named person, no stock photo).
// Present-tense, active-voice timeline. Overnight Impact numbers are illustrative
// and labelled as such. Part of #solutions.
const beats = [
  { time: '02:16', title: 'Detects drift', body: 'Tool-wear shift spotted on CNC-01 by the drift monitor.' },
  { time: '02:16', title: 'Triggers the pipeline', body: 'The CI pipeline starts automatically.' },
  { time: '02:20', title: 'Retrains the model', body: 'A new model trains on the latest factory data.' },
  { time: '02:37', title: 'Promotes the winner', body: 'The better model is promoted to production automatically.' },
  { time: '08:47', title: 'Reports all-clear', body: 'Maintenance lead checks the dashboard. No calls. No incidents.' },
];

const impact = [
  '1 potential failure prevented',
  '~8 hours of downtime avoided',
  '€24,300 saved',
  'Production stayed on track',
];
---

<section class="border-t border-white/5 bg-navy-950 py-20">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-bold tracking-tight sm:text-5xl">
        <span class="text-offwhite">While the employees</span>
        <span class="text-teal-400">sleep…</span>
      </h2>
      <p class="mt-4 text-lg text-muted">The system watches over the factory all night.</p>
    </div>

    <!-- Timeline: horizontal on lg, stacked on mobile -->
    <ol class="relative mt-14 grid gap-8 lg:grid-cols-5 lg:gap-4">
      <div class="absolute left-0 right-0 top-[7px] hidden h-px bg-gradient-to-r from-transparent via-teal-400/40 to-transparent lg:block" aria-hidden="true"></div>
      {
        beats.map((b) => (
          <li class="relative pl-6 lg:pl-0 lg:pt-6 lg:text-center">
            <span class="absolute left-0 top-1 h-3.5 w-3.5 rounded-full border-2 border-teal-400 bg-navy-950 lg:left-1/2 lg:top-0 lg:-translate-x-1/2" aria-hidden="true"></span>
            <p class="text-xs font-semibold tracking-wide text-teal-400">{b.time}</p>
            <h3 class="mt-1 text-sm font-semibold text-offwhite">{b.title}</h3>
            <p class="mt-1 text-xs leading-relaxed text-muted">{b.body}</p>
          </li>
        ))
      }
    </ol>

    <!-- 3-column: impact / avatar / summary -->
    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      <!-- Overnight Impact -->
      <div class="rounded-xl border border-white/10 bg-navy-800/40 p-6">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-lg font-semibold text-offwhite">Overnight Impact</h3>
          <span class="rounded-full border border-teal-400/50 px-2.5 py-0.5 text-[0.65rem] font-medium text-teal-300">
            Illustrative example
          </span>
        </div>
        <ul class="space-y-2.5">
          {
            impact.map((item) => (
              <li class="flex items-start gap-2 text-sm text-muted">
                <svg class="mt-0.5 shrink-0 text-teal-400" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
        <p class="mt-4 text-xs italic text-muted/60">
          A walkthrough of one night — not aggregated customer data.
        </p>
      </div>

      <!-- Avatar / silhouette (no photo of a real person) -->
      <div class="flex flex-col items-center justify-center rounded-xl border border-white/10 bg-gradient-to-b from-navy-800/60 to-navy-900 p-6 text-center">
        <svg width="88" height="88" viewBox="0 0 96 96" fill="none" aria-hidden="true">
          <circle cx="48" cy="48" r="46" stroke="rgba(45,212,191,0.35)" stroke-width="1.5" />
          <circle cx="48" cy="38" r="14" fill="rgba(45,212,191,0.5)" />
          <path d="M24 74c2-13 12-20 24-20s22 7 24 20" fill="rgba(45,212,191,0.5)" />
        </svg>
        <p class="mt-4 text-sm text-muted">The team rests. The pipeline doesn't.</p>
      </div>

      <!-- Morning Summary -->
      <div class="flex flex-col rounded-xl border border-white/10 bg-navy-800/40 p-6">
        <h3 class="text-lg font-semibold text-offwhite">Morning Summary</h3>
        <div class="mt-4 flex items-center gap-3">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border-2 border-teal-400 text-teal-400">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <p class="text-sm text-muted">No incidents.<br />Model upgraded overnight.</p>
        </div>
        <a
          href="#product"
          class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg bg-teal-400 px-5 py-2.5 text-sm font-semibold text-navy-950 transition-colors hover:bg-teal-300"
        >
          See it in action →
        </a>
      </div>
    </div>

    <p class="mt-14 text-center text-2xl font-semibold sm:text-3xl">
      <span class="text-offwhite">One system.</span>
      <span class="text-teal-400">Always learning.</span>
      <span class="text-offwhite">Always protecting.</span>
    </p>
  </div>
</section>
