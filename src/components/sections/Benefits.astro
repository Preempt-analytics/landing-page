---
// §9.4 Benefits — 4 tiles. The source screenshots were inconsistent (some light,
// some dark); restyled here into one consistent dark-card/teal-icon system, the
// same fix applied to the hero stat tiles. Maps to #solutions (part 1).
const benefits = [
  {
    title: 'Reduce Downtime',
    body: 'Prevent unexpected failures and unplanned stops.',
    icon: 'M12 7v5l3 2M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z',
  },
  {
    title: 'Extend Asset Life',
    body: 'Catch issues early and reduce wear and tear.',
    icon: 'M3 17l6-6 4 4 8-8M21 7v5M21 7h-5',
  },
  {
    title: 'Lower Maintenance Costs',
    body: 'Replace parts based on actual condition, not guesswork.',
    icon: 'M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18zM9.5 9.5a2.5 2.5 0 0 1 2.5-1.5c1.4 0 2.5.9 2.5 2s-1 1.6-2.5 2-2.5 1-2.5 2 1.1 2 2.5 2a2.5 2.5 0 0 0 2.5-1.5M12 6.5v11',
  },
  {
    title: 'Increase Operational Efficiency',
    body: 'More uptime. Smoother operations. Happier teams.',
    icon: 'M4 20V12M10 20V6M16 20v-9M22 20H2',
  },
];
---

<section id="solutions" class="scroll-mt-20 border-t border-white/5 bg-navy-900 py-20">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-teal-400">
        What it helps with
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-offwhite sm:text-4xl">
        Fewer surprises. Lower costs. Longer-lasting machines.
      </h2>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((b) => (
          <div class="rounded-xl border border-white/10 bg-navy-800/40 p-6">
            <div class="mb-4 inline-flex rounded-lg bg-teal-400/10 p-2.5 text-teal-400">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={b.icon} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-offwhite">{b.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{b.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
