---
import Button from './Button.astro';
import StatRow from './StatRow.astro';
import { withBase } from '../lib/site';
---

<section class="relative overflow-hidden">
  <!-- Cyberpunk glow overlay (separate from any photo, per §5) -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:
      radial-gradient(60% 55% at 78% 35%, rgba(45,212,191,0.16), transparent 70%),
      radial-gradient(45% 40% at 12% 8%, rgba(59,130,246,0.14), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 py-16 md:px-8 md:py-24 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- Copy column -->
    <div>
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.22em] text-blue-500">
        Predictive maintenance, powered by AI
      </p>

      <h1 class="text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        <span class="text-offwhite">Predict failures.</span><br />
        <span class="text-teal-400">Prevent</span> <span class="text-offwhite">downtime.</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
        Preempt Analytics helps manufacturing teams predict machine failures
        before they happen—so you can maximize uptime and efficiency.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="#product" variant="solid">See it in action →</Button>
        <Button href={withBase('/try-it-yourself')} variant="outline">
          Test it on your device
        </Button>
      </div>

      <p class="mt-5 text-xs text-muted/60">
        A capstone project showcase, running on simulated CNC sensor data.
      </p>

      <div class="mt-10">
        <StatRow />
      </div>
    </div>

    <!-- Visual column: gradient placeholder (macro-gears photo is an open item, §7) -->
    <div class="relative">
      <div class="relative aspect-[4/5] w-full overflow-hidden rounded-2xl border border-white/10 sm:aspect-square">
        <div
          class="absolute inset-0"
          style="background: linear-gradient(135deg, var(--color-navy-800), var(--color-navy-950) 55%, #06251f);"
          aria-hidden="true"
        >
        </div>
        <!-- faint gear silhouette stand-in -->
        <svg class="absolute inset-0 h-full w-full opacity-[0.12]" viewBox="0 0 200 200" fill="none" aria-hidden="true">
          <g stroke="var(--color-teal-300)" stroke-width="1.5">
            <circle cx="130" cy="95" r="52" />
            <circle cx="130" cy="95" r="30" />
            {
              Array.from({ length: 12 }).map((_, i) => {
                const a = (i / 12) * Math.PI * 2;
                const x1 = 130 + Math.cos(a) * 52;
                const y1 = 95 + Math.sin(a) * 52;
                const x2 = 130 + Math.cos(a) * 64;
                const y2 = 95 + Math.sin(a) * 64;
                return <line x1={x1} y1={y1} x2={x2} y2={y2} />;
              })
            }
          </g>
        </svg>
        <!-- particle dot-grid + glow -->
        <div
          class="absolute inset-0 mix-blend-screen"
          style="background-image: radial-gradient(rgba(94,234,212,0.5) 1px, transparent 1.4px); background-size: 22px 22px; opacity: 0.25;"
          aria-hidden="true"
        >
        </div>
        <div class="absolute bottom-4 left-4 rounded-md bg-navy-950/70 px-3 py-1.5 text-[0.7rem] font-medium text-muted/80 backdrop-blur-sm">
          Hero image placeholder — macro-gears photo pending
        </div>
      </div>
    </div>
  </div>
</section>
