---
// One hero stat tile. Styling rule (§5): all values render the same off-white;
// teal is reserved for the icon + a 1px top-border accent — one consistent system.
interface Props {
  value: string;
  label: string;
  caption: string;
  /** 'live' shows a teal dot; 'illustrative' is a quiet honesty label. */
  captionTone?: 'live' | 'illustrative' | 'plain';
}
const { value, label, caption, captionTone = 'plain' } = Astro.props;
---

<div class="relative rounded-xl border border-white/10 border-t-teal-400/70 bg-navy-800/40 p-5 backdrop-blur-sm">
  <div class="mb-3 text-teal-400">
    <slot name="icon" />
  </div>
  <div class="text-2xl font-bold text-offwhite">{value}</div>
  <div class="mt-0.5 text-sm font-medium text-offwhite/90">{label}</div>
  <div class="mt-2 flex items-center gap-1.5 text-xs text-muted/70">
    {
      captionTone === 'live' && (
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-teal-400" aria-hidden="true" />
      )
    }
    <span>{caption}</span>
  </div>
</div>
