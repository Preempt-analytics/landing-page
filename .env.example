# Live-metrics fetch (scripts/fetch-metrics.mjs). Used only in CI — never shipped to the browser.
#
# IMPORTANT: mint a DagsHub token FRESH for this repo (read-only scope if offered).
# Never copy the token/SSH key from the ML repo's .env.demo or .dvc/config — this repo
# has its own trust boundary. See docs/ARCHITECTURE.md §4 and §7 item 4.
DAGSHUB_USERNAME=
DAGSHUB_TOKEN=

# Public — already documented in the ML repo. A repo *variable*, not a secret.
MLFLOW_TRACKING_URI=https://dagshub.com/Preempt-Analytics-Demo/predictive-maintenance-demo.mlflow
