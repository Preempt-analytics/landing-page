---
// Reusable CTA button. Two visual variants (§5); the site uses exactly two CTA
// verbs — a "look" verb (See it in action) and a "do" verb (Test it on your device).
interface Props {
  href: string;
  variant?: 'solid' | 'outline';
  class?: string;
}
const { href, variant = 'solid', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold tracking-wide transition-colors duration-200';
const variants = {
  solid: 'bg-teal-400 text-navy-950 hover:bg-teal-300',
  outline:
    'border border-teal-400 text-teal-400 hover:bg-teal-400/10',
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</a>
